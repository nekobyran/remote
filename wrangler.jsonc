{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nkbr-release",
  "main": "worker.js",
  "compatibility_date": "2026-07-13",
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "routes": [
    {
      "pattern": "nkbr.cc/*",
      "zone_name": "nkbr.cc"
    }
  ]
}
